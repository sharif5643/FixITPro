# FixITPro APK Build Environment
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env.apk.local and fill in your values.
# .env.apk.local is gitignored — never commit it.
#
# APK Architecture: The APK is a WebView pointing at your production Next.js
# server. Both browser users and APK users hit the same server & database.
# ─────────────────────────────────────────────────────────────────────────────

# URL of your deployed Next.js frontend (must be HTTPS in production)
CAPACITOR_SERVER_URL=https://your-domain.com

# ── For Release Signing ───────────────────────────────────────────────────────
# KEYSTORE_PATH=C:/keys/fixitpro.keystore
# KEYSTORE_PASS=your-keystore-password
# KEY_ALIAS=fixitpro
# KEY_PASS=your-key-password
