# FixITPro Web App — Production Environment Template
# Copy this file to .env.production and fill in real values before deploying.
# NEVER commit .env.production to version control.
#
# Next.js loads .env.production automatically when NODE_ENV=production.
# Do NOT use .env.local alongside this file — .env.local overrides break DEV/PROD separation.

# ── API ──────────────────────────────────────────────────────────────────────
# Must point to the reachable IP/domain of the backend server.
# For LAN deploy: http://192.168.x.x:3000/api/v1
# For domain deploy: https://api.yourdomain.com/api/v1
NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP:3000/api/v1
