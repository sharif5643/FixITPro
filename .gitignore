# Dependencies
node_modules/

# Build outputs
dist/
.next/
out/

# Logs
logs/
*.log

# Backups
backups/

# Environment secrets — NEVER commit
.env
.env.*

# Keep example/template files (no secrets inside)
!.env.example
!.env.production.example
# .env.apk is a template with no secrets — intentionally tracked
!.env.apk
# .env.apk.local contains LAN IPs and local paths — gitignored (covered by .env.* above)

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# TypeScript build cache
*.tsbuildinfo

# Android APK build artifacts — distributed separately via GitHub Releases
# Specific prefixes only so .env.apk (a tracked template) is not affected
FixITPro-*.apk
FixIT+-*.apk

# Upload directory (runtime data, not source)
backend/uploads/

# Claude project settings (local only)
.claude/settings.local.json
