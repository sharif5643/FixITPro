# FixITPro Backend — Production Environment Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.production and fill in real values before deploying.
# NEVER commit .env.production to version control.
#
# When deploying via Docker / Coolify, set these as environment variables
# in Coolify UI (not as a file) — the values below are templates only.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Database ─────────────────────────────────────────────────────────────────
# For Docker / Coolify: use service name as host (postgres)
DATABASE_URL=postgresql://fixitpro_user:STRONG_PASSWORD@postgres:5432/fixitpro?schema=public
# For direct VPS (non-Docker): replace 'postgres' with actual host
# DATABASE_URL=postgresql://fixitpro_user:STRONG_PASSWORD@localhost:5432/fixitpro

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_96_CHAR_HEX_SECRET
JWT_EXPIRES_IN=8h

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
# Coolify example: https://app.yourshop.com
# Multiple: https://app.yourshop.com,https://admin.yourshop.com
CORS_ORIGIN=https://app.yourshop.com

# ── File storage (Docker volumes — paths inside the container) ────────────────
# Do NOT change these when using Docker — they match the volume mount in docker-compose
BACKUP_DIR=/app/backups
# UPLOADS_DIR defaults to /app/uploads (set in docker-entrypoint.sh)

# ── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL options: error | warn | info | debug (default: warn in production)
LOG_LEVEL=warn

# ── Super Admin seed (run once after first deploy) ────────────────────────────
# npm run seed:prod-super-admin
SUPER_ADMIN_EMAIL=superadmin@yourdomain.com
SUPER_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
SUPER_ADMIN_NAME=Super Admin
