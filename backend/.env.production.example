# FixITPro Backend — Production Environment Template
# Copy this file to .env.production and fill in real values before deploying.
# NEVER commit .env.production to version control.

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://PGUSER:PGPASSWORD@PGHOST:5432/PGDATABASE
# e.g. postgresql://postgres:strongpassword@localhost:5432/fixitpro_prod

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_96_CHAR_HEX_SECRET
JWT_EXPIRES_IN=8h

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
CORS_ORIGIN=http://YOUR_SERVER_IP:3001

# ── File storage ─────────────────────────────────────────────────────────────
UPLOADS_BASE_DIR=D:\FixITPro_Prod_Uploads
UPLOADS_DIR=D:\FixITPro_Prod_Uploads\repairs

# ── Backup ───────────────────────────────────────────────────────────────────
BACKUP_DIR=D:\FixITPro_Backups
BACKUP_RETENTION_DAYS=30

# ── Logging ──────────────────────────────────────────────────────────────────
LOGS_DIR=D:\FixITPro\backend\logs
# LOG_LEVEL options: error | warn | info | debug (default: warn in production)
LOG_LEVEL=warn

# ── Super Admin seed (used only once with: npm run seed:prod-super-admin) ────
SUPER_ADMIN_EMAIL=superadmin@yourdomain.com
SUPER_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
SUPER_ADMIN_NAME=Super Admin
